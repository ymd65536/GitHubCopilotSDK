{
    "name": "GitHubCopilotSDK",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        // Codespacesでのビルドエラーを防ぐため、こちらに変更（ローカルでも動きます）
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": "true"
        },
        "ghcr.io/devcontainers/features/github-cli:1": { "version": "latest" },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": { "version": "latest" }
    },
    "mounts": [
        "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube-host,type=bind,consistency=cached"
    ],
    "containerEnv": {
        "KUBECONFIG": "/home/vscode/.kube/config"
    },
    "runArgs": ["--add-host=host.docker.internal:host-gateway"],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "googlecloudtools.cloudcode",
                "GitHub.copilot"
            ]
        }
    },
    "postCreateCommand": "mkdir -p ~/.kube && if [ -f /home/vscode/.kube-host/config ]; then sed 's/127.0.0.1/host.docker.internal/g' /home/vscode/.kube-host/config > ~/.kube/config && kubectl config set-cluster $(kubectl config current-context) --insecure-skip-tls-verify=true; fi && pip install --no-cache github-copilot-sdk",
    "remoteUser": "vscode"
}